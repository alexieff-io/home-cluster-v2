            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "id": 55,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "100 * zfs_pool_allocated_bytes{job=\"truenas-zfs\",instance=\"$instance\"} / zfs_pool_size_bytes{job=\"truenas-zfs\",instance=\"$instance\"}",
          "legendFormat": "{{pool}}",
          "refId": "A" }
