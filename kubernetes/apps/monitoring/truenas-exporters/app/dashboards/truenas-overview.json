    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "panels": [],
      "title": "ZFS",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "left", "displayMode": "auto" },
          "mappings": [
            { "type": "value", "options": {
              "0": { "color": "green", "text": "ONLINE" },
              "1": { "color": "orange", "text": "DEGRADED" },
              "2": { "color": "red", "text": "FAULTED" },
              "3": { "color": "red", "text": "OFFLINE" },
              "4": { "color": "red", "text": "UNAVAIL" },
              "5": { "color": "red", "text": "REMOVED" },
              "6": { "color": "red", "text": "SUSPENDED" }
            } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "size" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "allocated" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "free" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "frag" }, "properties": [{ "id": "unit", "value": "percentunit" }] },
          { "matcher": { "id": "byName", "options": "dedup" }, "properties": [{ "id": "unit", "value": "none" }, { "id": "decimals", "value": 2 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "id": 50,
      "options": { "showHeader": true },
      "pluginVersion": "10.x",
      "targets": [
        { "expr": "zfs_pool_health{job=\"truenas-zfs\",instance=\"$instance\"}", "format": "table", "instant": true, "refId": "A" },
        { "expr": "zfs_pool_size_bytes{job=\"truenas-zfs\",instance=\"$instance\"}", "format": "table", "instant": true, "refId": "B" },
        { "expr": "zfs_pool_allocated_bytes{job=\"truenas-zfs\",instance=\"$instance\"}", "format": "table", "instant": true, "refId": "C" },
        { "expr": "zfs_pool_free_bytes{job=\"truenas-zfs\",instance=\"$instance\"}", "format": "table", "instant": true, "refId": "D" },
        { "expr": "zfs_pool_fragmentation_ratio{job=\"truenas-zfs\",instance=\"$instance\"}", "format": "table", "instant": true, "refId": "E" },
        { "expr": "zfs_pool_deduplication_ratio{job=\"truenas-zfs\",instance=\"$instance\"}", "format": "table", "instant": true, "refId": "F" }
      ],
      "title": "ZFS Pools",
      "transformations": [
        { "id": "joinByField", "options": { "byField": "pool", "mode": "outer" } },
        { "id": "filterFieldsByName", "options": { "include": { "names": ["pool", "Value #A", "Value #B", "Value #C", "Value #D", "Value #E", "Value #F"] } } },
        { "id": "organize", "options": {
          "excludeByName": {},
          "renameByName": {
            "Value #A": "health",
            "Value #B": "size",
            "Value #C": "allocated",
            "Value #D": "free",
            "Value #E": "frag",
            "Value #F": "dedup"
          }
        } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1, "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "red", "value": 0.95 }
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 51,
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "targets": [
        { "expr": "zfs_pool_allocated_bytes{job=\"truenas-zfs\",instance=\"$instance\"} / zfs_pool_size_bytes{job=\"truenas-zfs\",instance=\"$instance\"}",
          "legendFormat": "{{pool}}", "refId": "A" }
      ],
      "title": "Pool Capacity Used",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
