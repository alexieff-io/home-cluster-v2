      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"truenas-node\",instance=\"$instance\",device!~\"lo|docker.*|veth.*|br-.*\"}[2m])",
          "legendFormat": "{{device}} rx", "refId": "A" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"truenas-node\",instance=\"$instance\",device!~\"lo|docker.*|veth.*|br-.*\"}[2m])",
          "legendFormat": "{{device}} tx", "refId": "B" }
      ],
      "title": "Network Throughput (rx + / tx −)",
