      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"truenas-node\",instance=\"$instance\"} - node_memory_MemFree_bytes{job=\"truenas-node\",instance=\"$instance\"} - node_memory_Cached_bytes{job=\"truenas-node\",instance=\"$instance\"} - node_memory_Buffers_bytes{job=\"truenas-node\",instance=\"$instance\"} - (node_memory_Slab_bytes{job=\"truenas-node\",instance=\"$instance\"} or vector(0))",
          "legendFormat": "used", "refId": "A" },
        { "expr": "node_memory_Cached_bytes{job=\"truenas-node\",instance=\"$instance\"} + (node_memory_Buffers_bytes{job=\"truenas-node\",instance=\"$instance\"} or vector(0))",
          "legendFormat": "cache+buffers", "refId": "B" },
        { "expr": "node_zfs_arcstats_size{job=\"truenas-node\",instance=\"$instance\"} or vector(0)",
          "legendFormat": "zfs ARC", "refId": "C" },
        { "expr": "node_memory_MemFree_bytes{job=\"truenas-node\",instance=\"$instance\"}",
          "legendFormat": "free", "refId": "D" }
      ],
      "title": "Memory Breakdown",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
