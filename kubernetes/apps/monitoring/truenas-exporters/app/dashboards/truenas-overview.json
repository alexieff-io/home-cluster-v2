        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "binBps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
