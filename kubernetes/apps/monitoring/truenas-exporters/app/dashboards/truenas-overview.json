        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "node_memory_SwapTotal_bytes{job=\"truenas-node\",instance=\"$instance\"} - node_memory_SwapFree_bytes{job=\"truenas-node\",instance=\"$instance\"}",
          "legendFormat": "swap used", "refId": "A" },
        { "expr": "node_memory_SwapTotal_bytes{job=\"truenas-node\",instance=\"$instance\"}",
          "legendFormat": "swap total", "refId": "B" }
      ],
      "title": "Swap",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
