  },
  "description": "Single-pane overview of TrueNAS host metrics: system health, CPU, memory, network, disk I/O, ZFS pools and datasets, ARC cache, and SMART drive health. Sources: node_exporter + zfs_exporter + smartctl_exporter.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "10.x",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "time() - node_boot_time_seconds{job=\"truenas-node\",instance=\"$instance\"}",
          "refId": "A" }
      ],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100, "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"truenas-node\",instance=\"$instance\",mode=\"idle\"}[2m])) * 100)",
          "refId": "A" }
      ],
      "title": "CPU Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100, "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "red", "value": 95 }
          ]},
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"truenas-node\",instance=\"$instance\"} / node_memory_MemTotal_bytes{job=\"truenas-node\",instance=\"$instance\"}))",
          "refId": "A" }
      ],
      "title": "Memory Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 4 },
            { "color": "red", "value": 8 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "node_load1{job=\"truenas-node\",instance=\"$instance\"}",
          "refId": "A" }
      ],
      "title": "Load (1m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "count(zfs_pool_health{job=\"truenas-zfs\",instance=\"$instance\"})",
          "refId": "A" }
      ],
      "title": "ZFS Pools",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "count(zfs_pool_health{job=\"truenas-zfs\",instance=\"$instance\"} > 0) OR on() vector(0)",
          "refId": "A" }
      ],
      "title": "Pools Not Healthy",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "CPU & Load",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "min": 0, "max": 100,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"truenas-node\",instance=\"$instance\",mode!=\"idle\"}[2m])) / scalar(count(count by (cpu) (node_cpu_seconds_total{job=\"truenas-node\",instance=\"$instance\"}))) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A" }
      ],
      "title": "CPU Usage by Mode",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "node_load1{job=\"truenas-node\",instance=\"$instance\"}", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5{job=\"truenas-node\",instance=\"$instance\"}", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15{job=\"truenas-node\",instance=\"$instance\"}", "legendFormat": "15m", "refId": "C" }
      ],
      "title": "Load Average",
      "type": "timeseries"
    },
    {
